---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base>
  <main class="hero">
    <div class="hero-shell">
      <h1 class="hero-name">Tomoki Sawai</h1>
      <p class="hero-role reveal">Diffusion<span class="sep">/</span>ML<span class="sep">/</span>NMR</p>
      <p class="hero-summary reveal">
        My research focuses on accelerating and improving MRI reconstruction through diffusion-based posterior sampling techniques.
      </p>
      <nav class="hero-links reveal" aria-label="Links">
        <a class="link" href="https://www.instagram.com/81_arigato/?hl=ja" rel="me noopener" target="_blank">Instagram</a>
        <a class="link" href="https://www.kaggle.com/shiru2" rel="me noopener" target="_blank">Kaggle</a>
        <a class="link" href="https://github.com/shiru2" rel="me noopener" target="_blank">GitHub</a>
      </nav>
      <a class="works-preview reveal" href={`${base}works/`}>Works</a>
    </div>
  </main>
</Base>
