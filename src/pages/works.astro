---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base title="Tomoki Sawai — Works" description="Selected works and research notes by Tomoki Sawai.">
  <main class="works-page">
    <section class="works-hero">
      <p class="hero-kicker reveal">Works</p>
      <h1 class="hero-name">Works</h1>
      <p class="hero-summary reveal">
        Under construction.
      </p>
      <p class="hero-note reveal">
        <a class="inline-url" href={base}>back</a>
      </p>
    </section>
  </main>
</Base>
